# Application
PROJECT_NAME="AI HRMS"
API_V1_STR="/api/v1"
DEBUG=false
ENVIRONMENT=production

# Security
SECRET_KEY=your-256-bit-secret-key-here-change-in-production
SECRET_KEY_PREVIOUS=
REFRESH_SECRET_KEY=your-refresh-secret-key-here-change-in-production
REFRESH_SECRET_KEY_PREVIOUS=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database
# Prefer DATABASE_URL in production if your host provides one.
# DigitalOcean Managed MySQL example:
# DATABASE_URL=mysql+pymysql://doadmin:password@db-mysql-blr1-xxxxx-do-user-xxxxx-0.b.db.ondigitalocean.com:25060/ai_hrms?charset=utf8mb4
DATABASE_URL=
MYSQL_USER=hrms_user
MYSQL_PASSWORD=strong_password_here
MYSQL_SERVER=db-mysql-region-name-do-user-000000-0.b.db.ondigitalocean.com
MYSQL_PORT=25060
MYSQL_DB=ai_hrms
MYSQL_SSL_CA=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
MAIL_USERNAME=noreply@yourcompany.com
MAIL_PASSWORD=email_password
MAIL_FROM=noreply@yourcompany.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png

# AI / OpenAI
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# CORS
BACKEND_PUBLIC_URL=https://api.yourdomain.com
FRONTEND_PUBLIC_URL=https://hrms.yourdomain.com
BACKEND_CORS_ORIGINS=["https://hrms.yourdomain.com","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TIMEZONE=Asia/Kolkata
