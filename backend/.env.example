# Application
PROJECT_NAME="AI HRMS"
API_V1_STR="/api/v1"
DEBUG=false
ENVIRONMENT=production

# Security
SECRET_KEY=your-256-bit-secret-key-here-change-in-production
REFRESH_SECRET_KEY=your-refresh-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database
MYSQL_USER=hrms_user
MYSQL_PASSWORD=strong_password_here
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DB=ai_hrms

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
MAIL_USERNAME=noreply@yourcompany.com
MAIL_PASSWORD=email_password
MAIL_FROM=noreply@yourcompany.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png

# AI / OpenAI
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
